<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.Finance" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/teal_200</item> <!-- Black -->
        <item name="colorPrimaryDark">@color/teal_200</item> <!-- Black -->
        <item name="colorAccent">@color/teal_200</item> <!-- Gold Accent -->
        <!-- Customize your theme here -->
    </style>

    <!-- No ActionBar Theme (Fixed Version) -->
    <style name="Theme.Finance.NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Custom EditText Style -->
    <style name="edit_text">
        <item name="android:gravity">start</item>
        <item name="textFillColor">@color/black</item>
        <item name="paddingStart">15sp</item>
        <item name="background">@color/vintage_text_secondary</item>
        <item name="android:radius">20sp</item>
    </style>

    <style name="CustomButtonStyleItemised" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/rounded_conners_with_gradient</item>
        <item name="android:textColor">@color/cardview_shadow_start_color</item>
        <item name="android:elevation">0dp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minWidth">120dp</item>
        <item name="android:height">60dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">20sp</item>
        <item name="android:drawablePadding">10dp</item>
        <item name="android:layoutDirection">rtl</item>
    </style>


    <style name="CustomButtonStyle3" parent="Widget.AppCompat.Button">
        <!--        <item name="theme">@style/AppTheme</item>-->
        <item name="android:background">@drawable/rounded_conners_with_gradient</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:padding">12sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:elevation">0dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
    </style>



    <style name="Theme.Finance.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="Theme.Finance.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>
